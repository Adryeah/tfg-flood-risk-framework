# ─── Docker build context filter ─────────────────────────────────
# Keep the image small by excluding everything the backend doesn't
# need at runtime. The Dockerfile only COPYs specific paths so most
# of this is defence-in-depth — but the build context itself stays
# slim, which is what Render uploads on every deploy.
# ──────────────────────────────────────────────────────────────────

# Git + IDE
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Python venv + cache (we install from requirements.txt fresh in the image)
.venv/
venv/
**/__pycache__/
*.py[cod]
*.egg-info/

# Frontend — built and deployed separately to Vercel
framework_web/frontend/

# Logs and runtime artifacts
*.log
**/dev.log
**/dev.err.log
**/backend.log
**/backend.err.log
logs/

# Raw Sentinel scenes (multi-GB, generated by pipeline, not needed in API)
data/sentinel1/raw/
data/sentinel1/processed/
data/sentinel2/raw/
data/sentinel2/processed/
data/dem/
data/extrapolation/
data/features/
data/ems/

# Results + diagnostics
results/
capturas/
docs/

# Notebooks + LaTeX + pipeline scripts (not needed for serving)
notebooks/
*.ipynb
scripts/

# Other model files we don't ship (only v2 goes in the image)
models/random_forest_quick.joblib
models/random_forest_v1.joblib
models/xgboost_v3.joblib
models/xgboost_v3_DEPRECATED.joblib

# Misc top-level scratch
tools/
tests/
conftest.py
pytest.ini
uvicorn.log
README.md
CLAUDE.md
