# =============================================================================
# .gitignore — TFG Earth Intelligence
# =============================================================================

# ---------------------------------------------------------------------------
# Datos satelitales (voluminosos, no versionar)
# ---------------------------------------------------------------------------
data/sentinel1/raw/
data/sentinel1/processed/
data/sentinel2/raw/
data/sentinel2/processed/
data/dem/*.tif
data/extrapolation/
!data/**/.gitkeep

# ---------------------------------------------------------------------------
# Credenciales (NUNCA versionar)
# ---------------------------------------------------------------------------
config/copernicus_credentials.yaml
*.env
.env

# ---------------------------------------------------------------------------
# Modelos entrenados (reproducibles desde código)
# ---------------------------------------------------------------------------
models/trained/*.joblib

# ---------------------------------------------------------------------------
# SNAP / BEAM
# ---------------------------------------------------------------------------
*.dim
*.data/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# Entornos virtuales
# ---------------------------------------------------------------------------
venv/
.venv/
env/
.env/

# ---------------------------------------------------------------------------
# Sistema operativo
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# Frontend build artifacts
# ---------------------------------------------------------------------------
node_modules/
framework_web/frontend/dist/
framework_web/frontend/.vite/
framework_web/frontend/dev.log
framework_web/frontend/dev.err.log

# ---------------------------------------------------------------------------
# Backend runtime artifacts
# ---------------------------------------------------------------------------
framework_web/backend/backend.log
framework_web/backend/backend.err.log
framework_web/backend/__pycache__/

# ---------------------------------------------------------------------------
# Logs varios
# ---------------------------------------------------------------------------
logs/*.log
*.log

# ---------------------------------------------------------------------------
# Local Claude / agent config — no se sube
# ---------------------------------------------------------------------------
.agents/
.claude/
skills-lock.json
.markdownlint.json

# ---------------------------------------------------------------------------
# Local caches y outputs (no son fuente reproducible)
# ---------------------------------------------------------------------------
cache/
capturas/
results/
notebooks/

# ---------------------------------------------------------------------------
# Memoria LaTeX y docs internos
# (pueden contener info personal — los excluimos del repo público;
#  añade selectivamente lo que quieras compartir.)
# ---------------------------------------------------------------------------
docs/
ESTRUCTURA_PROYECTO.md
Proyecto.md
DESIGN.md
Software.md
roadmap.md

# ---------------------------------------------------------------------------
# Datos: solo va al repo el subset procesado del backend
# (framework_web/backend/data_processed/). Todo lo demás se queda local.
# ---------------------------------------------------------------------------
data/

# ---------------------------------------------------------------------------
# Modelos: solo va al repo el RF v2 que sirve el backend en producción.
# Los demás (v1, quick, xgboost v3 leakage) se quedan locales.
# ---------------------------------------------------------------------------
models/*
!models/random_forest_v2.joblib

# ---------------------------------------------------------------------------
# Scratch / runtime
# ---------------------------------------------------------------------------
uvicorn.log
framework_web/__pycache__/
