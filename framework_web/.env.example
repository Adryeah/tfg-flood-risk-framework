# Copiar a .env y ajustar.
# Variables disponibles para el backend FastAPI.

# Puerto del API (uvicorn)
API_PORT=8000

# Modo debug (CORS abierto a *, logs DEBUG)
DEBUG=true

# Origenes CORS permitidos (lista JSON-like, solo aplica si DEBUG=false)
# CORS_ORIGINS=["http://localhost:8080", "http://localhost:5173"]

# Threshold operacional Valencia (criterio recall>=0.75)
THRESHOLD_OPERATIONAL=0.614

# Threshold operacional Algemesi (max F1 recalibrado sobre extrapolacion)
THRESHOLD_OPERATIONAL_ALGEMESI=0.389
